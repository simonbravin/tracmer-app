# tracmer-app — plantilla (sin secretos reales)
# Copiá como `.env` o `.env.local` en la raíz; Next.js carga `apps/web` desde allí
# o desde `apps/web/.env*`. Ajustá según tu despliegue.
#
# Documentación: README (raíz), `docs/deploy/DEPLOY.md`, `apps/web/README`, `packages/database/README`.

# --- Base de datos (obligatoria al usar la app con Prisma) ---
# Postgres (p. ej. Neon): SSL suele requerirse.
DATABASE_URL="postgresql://USUARIO:CLAVE@HOST/DB?sslmode=require"

# --- Clerk (obligatorias con shell autenticado y sign-in) ---
# Claves del dashboard: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxx"
CLERK_SECRET_KEY="sk_test_xxxx"

# Signing secret del endpoint en Clerk (Svix). En producción el route /api/webhooks/clerk
# responde 503 si falta: no acepta webhooks sin verificar firma.
# En desarrollo, sin esta variable, el endpoint responde 200 sin verificar (solo pruebas locales).
# CLERK_WEBHOOK_SECRET="whsec_xxxx"

# --- Opcional: primer arranque (sin otras orgs) — nombre de la org por defecto
# DEFAULT_ORGANIZATION_NAME="Organización"

# Desactiva la validación Zod estricta en el servidor (solo CI/build sin conexión real, etc.)
# No usar en producción.
# SKIP_ENV_VALIDATION=1

# --- Reportes programados (Resend + job manual / cron externo) ---
# RESEND_API_KEY="re_xxxx"
# Remitente verificado en Resend (dominio propio o sandbox de pruebas)
# RESEND_FROM="Transporte <noreply@tudominio.com>"
# Protege POST /api/jobs/run-reports (Bearer token). En prod sin esto el endpoint responde 503.
# La ruta no usa sesión Clerk (middleware la deja pública); el secreto es la única barrera.
# CRON_SECRET="generar-un-secreto-largo"
